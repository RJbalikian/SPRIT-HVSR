{
  "name": "SpRIT Codespace",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "mathematic.vscode-pdf"
      ]
    }
  },

  "postCreateCommand": [
    "pip3 install --upgrade pip",
    "pip3 install uv",
    "uv pip install sprit ipykernel --upgrade --system"    
  ]
}
