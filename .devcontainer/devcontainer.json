{
  "name": "SpRIT Codespace",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "mathematic.vscode-pdf"
      ]
    }
  },

  "postCreateCommand": [
    "pip3 install --upgrade pip",
    "pip3 install uv",
    "uv venv .venv",
    "source .venv/bin/activate",
    "uv pip install sprit ipykernel --upgrade"
  ]
}
