{
  "name": "SpRIT Codespace",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  },

  "postCreateCommand": [
    "pip install --upgrade pip",
    "pip install uv",
    "uv pip install sprit ipykernel --upgrade"    
  ]
}
